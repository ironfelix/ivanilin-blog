---
export interface Props {
  imageUrl?: string;
}

const { imageUrl } = Astro.props;
---

<div class="hero">
  <div class="hero-avatar">
    {imageUrl ? (
      <img src={imageUrl} alt="Иван Ильин" class="hero-photo" />
    ) : (
      <div class="hero-photo-placeholder">
        <span>?</span>
      </div>
    )}
  </div>
  <div class="hero-text">
    <p class="hero-greeting">Привет! Меня зовут <strong>Иван Ильин.</strong></p>
    <p class="hero-bio">Занимаюсь маркетингом, строю AI-продукты, разбираюсь как технологии меняют бизнес и тело.</p>
    <p class="hero-desc">Веду этот блог — про AI, маркетинг, здоровье, книги и эксперименты. Без лекций. С фактами и вопросами.</p>
  </div>
</div>

<style>
  .hero {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    margin-bottom: 3rem;
  }

  .hero-avatar {
    flex-shrink: 0;
  }

  .hero-photo,
  .hero-photo-placeholder {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
  }

  .hero-photo-placeholder {
    background: var(--color-admonition-note);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    color: var(--color-background);
    opacity: 0.25;
  }

  .hero-text {
    flex: 1;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .hero-greeting {
    margin: 0 0 0.6rem;
    font-size: 1.2rem;
  }

  .hero-bio {
    margin: 0 0 0.6rem;
  }

  .hero-desc {
    margin: 0;
    color: var(--color-foreground);
    opacity: 0.75;
  }

  @media (max-width: 600px) {
    .hero {
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
      gap: 1rem;
    }

    .hero-avatar {
      align-self: center;
    }

    .hero-photo,
    .hero-photo-placeholder {
      width: 100px;
      height: 100px;
    }

    .hero-text {
      font-size: 1rem;
    }
  }
</style>
